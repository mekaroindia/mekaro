# --- DATABASE CONFIGURATION ---
# Set to your Supabase PostgreSQL connection string
# Format: postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# --- EMAIL API (RESEND) ---
RESEND_API_KEY=your_resend_api_key

# --- SMTP EMAIL CONFIGURATION (OPTIONAL) ---
EMAIL_HOST_USER=your_email_host_user
EMAIL_HOST_PASSWORD=your_email_host_password

# --- CLOUDINARY STORAGE CONFIGURATION (OPTIONAL) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- DJANGO SETTINGS ---
# Optional: Set secret key override
# SECRET_KEY=your_custom_secret_key
